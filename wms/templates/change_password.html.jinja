{% extends "base.html.jinja" %}
{% from 'bootstrap5/form.html' import render_field %}

{% block content %}
<div class="container">
    <div class="row justify-content-center g-4">
        <div class="col-md-6">
            <div class="card mt-5">
                <div class="card-header">
                    <h4 class="text-center">{{ '账户管理' if current_user.is_admin else '修改密码' }}</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        {{ form.csrf_token }}
                        {{ render_field(form.username) }}
                        {% if not current_user.is_admin %}
                        {{ render_field(form.old_password) }}
                        {% endif %}
                        {{ render_field(form.new_password) }}
                        {{ render_field(form.confirm_password) }}
                        {{ render_field(form.submit) }}
                    </form>
                </div>
            </div>
        </div>

        {% if current_user.is_admin and account_form %}
        <div class="col-md-6">
            <div class="card mt-5">
                <div class="card-header">
                    <h4 class="text-center">新建账户</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        {{ account_form.csrf_token }}
                        {{ render_field(account_form.username) }}
                        {{ render_field(account_form.nickname) }}
                        {{ render_field(account_form.role) }}
                        {{ render_field(account_form.password) }}
                        {{ render_field(account_form.confirm_password) }}
                        {{ render_field(account_form.submit) }}
                    </form>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}